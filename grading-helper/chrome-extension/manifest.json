{
  "manifest_version": 3,
  "name": "Grading Helper",
  "version": "1.0.0",
  "description": "PSAフォームへのカード情報自動入力",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.psacard.com/*",
    "http://localhost/*",
    "https://*.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.psacard.com/*"],
      "js": ["content/psa.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
