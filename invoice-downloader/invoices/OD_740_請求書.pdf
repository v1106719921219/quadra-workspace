		<title>印刷プレビュー</title>
	<style type="text/css" media="print">



	    /* 縦向に印刷 */
	    @page
	    {
	    	/* size:landscape;  */
	    	margin-top: 10mm;  /* this affects the margin in the printer settings */
	        margin-bottom: 0mm;  /* this affects the margin in the printer settings */
	    }

		.print_page{
		/*
		    width: 172mm;
		    height: 251mm;
		 */
		    page-break-after: always;
		    position: relative;
		    counter-increment: print_page_count; /* ページ番号のインクリメント */
		}
		.print_page:last-child{
		    page-break-after: auto;
		}
		.print_page:before{
		    position: absolute;
		    right: 0;
		    top: 0;
		    content: "";
		    margin-top:20mm;
		}
		.print_page:after{
		    position: absolute; /* 位置の相対指定 */
		    right: 0; /* 右から０ピクセルの位置指定 */
		    bottom: 0; /* 下から０ピクセルの位置指定 */
		  /*  content: counter(print_page_count) " / " counter(pages) ;  ページ番号を擬似要素に表示→自力で出力する為、不要 */
		}


		table .bg-grey1{background: #f7f7f7 !important;}


	</style>

